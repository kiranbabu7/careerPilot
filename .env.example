# Database
POSTGRES_DB=careerpilot
POSTGRES_USER=careerpilot
POSTGRES_PASSWORD=careerpilot
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://careerpilot:careerpilot@db:5432/careerpilot

# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production security (applied when DJANGO_DEBUG=false)
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_PRELOAD=false

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google OAuth (Phase 1: token verification only)
# Use the same Web client ID for both vars (docker-compose falls back automatically).
GOOGLE_OAUTH_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Production reverse proxy (Caddy in docker-compose.prod.yml)
# Set these to your real domains in production, e.g. app.example.com and api.example.com.
CADDY_APP_DOMAIN=localhost
CADDY_API_DOMAIN=api.localhost
# Optional email for Let's Encrypt account notifications.
CADDY_EMAIL=

# Redis / Celery (required for background workflows and scheduled job search)
# Docker Compose sets these to redis://redis:6379/0 for backend, worker, and beat.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# How often Beat checks for due scheduled searches (minutes). Default: 5.
CELERY_BEAT_SCHEDULE_INTERVAL=5

# Observability (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# AI (server-side only — never expose to frontend)
# Resume analysis uses google/gemini-2.5-flash via OpenRouter (hardcoded in providers.py).
OPENAI_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RESUME_MAX_UPLOAD_SIZE=5242880

# Job discovery (server-side only)
APIFY_API_TOKEN=
# Comma-separated Apify actors. LinkedIn-only example (use your actor ID from Apify Console):
# APIFY_JOB_ACTOR_IDS=linkedin:your-linkedin-actor-id
# Bare actor IDs default to LinkedIn. Add more boards later, e.g.:
# APIFY_JOB_ACTOR_IDS=linkedin:actorId,indeed:username~indeed-scraper
APIFY_JOB_ACTOR_IDS=
APIFY_DEFAULT_DATASET_LIMIT=50
TAVILY_API_KEY=
JOB_SEARCH_MAX_RESULTS=30

# Scheduled job search (user preferences, not env vars)
# Enable per user via PATCH /api/v1/users/preferences/ or Settings UI:
#   job_search_schedule_enabled: true
#   job_search_schedule_interval_minutes: 60 | 240 | 720 | 1440
# Requires celery-worker + celery-beat running and APIFY_* configured.
# Only fetches listings posted since last_job_search_at (incremental).
# Skip reasons stored in last_schedule_message; visible via schedule-status API.
# Restart celery-worker after backend code changes: docker compose restart celery-worker

# Production file storage (S3)
# Dev uses local ./media. Production: set USE_S3_STORAGE=true and configure bucket.
USE_S3_STORAGE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# Optional: CloudFront or custom domain for media URLs
# AWS_S3_CUSTOM_DOMAIN=
# Optional: S3-compatible endpoint (MinIO, LocalStack)
# AWS_S3_ENDPOINT_URL=
# Object key prefix inside the bucket (default: media)
# AWS_S3_MEDIA_PREFIX=media
